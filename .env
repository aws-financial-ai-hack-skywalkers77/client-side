# FastAPI base (browser calls this host for PDFs — not the Vite dev server). Prefer VITE_API_URL or VITE_API_BASE_URL.
VITE_API_BASE_URL=http://localhost:8001
# VITE_API_URL=http://localhost:8001

# Client sends highlighted=true on pdf_url and /pdf routes; backend should presign invoices/{db_id}/{invoice_id}_highlighted.pdf when present. Set to false to request the original PDF only.
# VITE_PDF_USE_HIGHLIGHTED=false
